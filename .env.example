# Required on Vercel for automatic intake email delivery
RESEND_API_KEY=
NAS_INTAKE_FROM=NAS CodeWorks <onboarding@resend.dev>

# Optional: when set, this overrides the recipient email entered in the admin panel.
NAS_INTAKE_TO=

# Required for cloud admin content storage through Supabase REST API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
